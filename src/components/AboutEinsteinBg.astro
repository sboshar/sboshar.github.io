---
/**
 * Full-viewport background: wireframe H7/H8 hat continuum (Tile(a,b) morph).
 * Small glow follows the pointer; touching a hat wire spawns light that runs both ways along that tile’s edge, fading with distance and time.
 */
---

<div class="einstein-hat-bg-root">
  <canvas
    id="einstein-hat-canvas"
    width="300"
    height="150"
    aria-hidden="true"
    tabindex="-1"
  ></canvas>
</div>

<script>
  import { initEinsteinHatBg } from '../scripts/einstein-hat-bg.ts';

  initEinsteinHatBg('einstein-hat-canvas');
</script>

<style>
  .einstein-hat-bg-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .einstein-hat-bg-root canvas {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    opacity: 0.35;
    /* One GPU filter pass over the bitmap — replaces heavy canvas shadowBlur per tile. */
    filter: blur(0.45px)
      drop-shadow(0 0 10px rgba(130, 150, 255, 0.42))
      drop-shadow(0 0 24px rgba(130, 150, 255, 0.22));
    transform: translateZ(0);
  }

  :global(.dark) .einstein-hat-bg-root canvas {
    opacity: 0.32;
    filter: blur(0.4px)
      drop-shadow(0 0 10px rgba(200, 215, 255, 0.38))
      drop-shadow(0 0 22px rgba(200, 215, 255, 0.18));
  }

  @media (prefers-reduced-motion: reduce) {
    .einstein-hat-bg-root canvas,
    :global(.dark) .einstein-hat-bg-root canvas {
      filter: none;
    }
  }
</style>
