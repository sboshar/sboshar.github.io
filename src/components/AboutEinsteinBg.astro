---
/**
 * Full-viewport background: wireframe H7/H8 hat continuum (Tile(a,b) morph).
 * Glow on the wire under the pointer; touching a hat wire spawns pulses along that tile’s perimeter.
 */
---

<div class="einstein-hat-bg-root">
  <canvas
    id="einstein-hat-canvas"
    width="300"
    height="150"
    aria-hidden="true"
    tabindex="-1"
  ></canvas>
</div>

<script>
  import { initEinsteinHatBg } from '../scripts/einstein-hat-bg.ts';

  initEinsteinHatBg('einstein-hat-canvas');
</script>

<style>
  .einstein-hat-bg-root {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    /* Own compositing layer: less repaint coupling while main content scrolls on mobile. */
    isolation: isolate;
  }

  .einstein-hat-bg-root canvas {
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    opacity: 0.3;
    /* One GPU filter pass over the bitmap — replaces heavy canvas shadowBlur per tile. */
    /* Light mode: halo matches body text (#1a1a1a) */
    filter: blur(0.45px)
      drop-shadow(0 0 10px rgba(26, 26, 26, 0.14))
      drop-shadow(0 0 24px rgba(26, 26, 26, 0.08));
    transform: translateZ(0);
  }

  :global(.dark) .einstein-hat-bg-root canvas {
    opacity: 0.28;
    filter: blur(0.4px)
      drop-shadow(0 0 10px rgba(200, 215, 255, 0.28))
      drop-shadow(0 0 22px rgba(200, 215, 255, 0.13));
  }

  @media (prefers-reduced-motion: reduce) {
    .einstein-hat-bg-root canvas,
    :global(.dark) .einstein-hat-bg-root canvas {
      filter: none;
    }
  }
</style>
