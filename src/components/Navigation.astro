---
const navItems = [
  { href: '/', label: 'about' },
  { href: '/publications', label: 'publications' },
  { href: '/teaching', label: 'teaching' },
  { href: '/cv', label: 'cv' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="fixed top-4 right-4 z-50 flex items-center gap-6">
  {navItems.map((item) => {
    const isActive =
      item.href === '/'
        ? currentPath === '/'
        : currentPath === item.href || currentPath.startsWith(`${item.href}/`);
    return (
    <a
      href={item.href}
      class={`text-sm hover:underline ${isActive ? 'font-semibold' : ''}`}
    >
      {item.label}
    </a>
    );
  })}
</nav>
