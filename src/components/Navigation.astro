---
import { siteHref, normalizePathname } from '../lib/site-url';

const navItems = ['about', 'publications', 'teaching', 'projects', 'cv'].map((segment) => ({
  label: segment === 'about' ? 'about' : segment,
  href: segment === 'about' ? siteHref() : siteHref(segment),
}));

const current = normalizePathname(Astro.url.pathname);
const homePath = normalizePathname(siteHref());
---

<nav class="fixed top-4 right-4 z-50 flex items-center gap-6">
  {navItems.map((item) => {
    const itemPath = normalizePathname(item.href);
    const isActive =
      itemPath === homePath
        ? current === homePath
        : current === itemPath || current.startsWith(`${itemPath}/`);
    return (
    <a
      href={item.href}
      class={`text-sm hover:underline ${isActive ? 'font-semibold' : ''}`}
    >
      {item.label}
    </a>
    );
  })}
</nav>
