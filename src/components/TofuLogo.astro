---
import { siteHref } from '../lib/site-url';
import tofuInline from '../assets/tofu-inline.svg?raw';
---

<a
  href={siteHref()}
  class="tofu-logo-link fixed top-5 left-5 z-50 block h-20 w-20 transition-opacity hover:opacity-70"
  aria-label="Home"
  set:html={tofuInline}
/>

<style>
  .tofu-logo-link :global(svg) {
    display: block;
    height: 100%;
    width: 100%;
    object-fit: contain;
    object-position: top;
  }
</style>
