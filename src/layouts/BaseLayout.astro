---
import TofuLogo from '../components/TofuLogo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import Navigation from '../components/Navigation.astro';
import AboutEinsteinBg from '../components/AboutEinsteinBg.astro';
import { siteHref } from '../lib/site-url';

interface Props {
  title: string;
  description?: string;
  /** Wireframe hat tiling behind content (animated canvas). Enable on about/home only. */
  einsteinBg?: boolean;
}

const { title, description, einsteinBg = false } = Astro.props;

const metaDescription = description || title;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={metaDescription} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <link rel="icon" type="image/svg+xml" href={siteHref('assets/svg/tofu.svg')} />
    <meta name="generator" content={Astro.generator} />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem('theme');
          const prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          const theme = stored || (prefersDark ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
        } catch {}
      })();
    </script>
    <title>{title}</title>
  </head>
  <body class="min-h-screen font-sans antialiased" style="background-color: var(--global-bg-color); color: var(--color-text);">
    <TofuLogo />
    <Navigation />
    <ThemeToggle />
    {einsteinBg && <AboutEinsteinBg />}
    <main class:list={['max-w-4xl mx-auto px-6 py-24', { 'relative z-10': einsteinBg }]}>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
