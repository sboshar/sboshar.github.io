---
import BaseLayout from '../layouts/BaseLayout.astro';

const blogPosts = [
  {
    title: "Understanding Transformer Architectures in Genomics",
    date: "2025-01-15",
    description: "A deep dive into how transformer models are revolutionizing the field of genomics, with a focus on sequence modeling and protein structure prediction.",
    category: "Machine Learning",
    link: "#"
  },
  {
    title: "Building Scalable ML Systems: Lessons from Production",
    date: "2024-12-10",
    description: "Practical insights on deploying machine learning models at scale, covering infrastructure, monitoring, and optimization strategies.",
    category: "Engineering",
    link: "#"
  },
  {
    title: "The Future of Foundation Models in Biology",
    date: "2024-11-22",
    description: "Exploring how large-scale foundation models are transforming biological research and drug discovery pipelines.",
    category: "Research",
    link: "#"
  },
  {
    title: "From Academia to Industry: A Research Engineer's Journey",
    date: "2024-10-05",
    description: "Reflections on transitioning from academic research to industry, and how to bridge the gap between theory and practice.",
    category: "Career",
    link: "#"
  },
  {
    title: "Optimizing Training Pipelines for Large Language Models",
    date: "2024-09-18",
    description: "Technical deep dive into efficient training strategies, including gradient checkpointing, mixed precision, and distributed training.",
    category: "Machine Learning",
    link: "#"
  }
];

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title="Blog">
  <div class="space-y-12">
    <div class="space-y-6">
      <h1>
        <img src="/assets/svg/blog_title.svg" alt="MiniBatch Press" class="blog-title-svg svg-theme" />
      </h1>
      <p class="text-sm">
        Blog posts and articles.
      </p>
    </div>

    <div class="space-y-8">
      {blogPosts.map((post) => (
        <article class="space-y-2 pb-8 border-b border-gray-200 dark:border-gray-800 last:border-0">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <h2 class="text-xl font-semibold">
                <a href={post.link} class="hover:underline">
                  {post.title}
                </a>
              </h2>
              <div class="flex items-center gap-3 mt-2">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                  {formatDate(post.date)}
                </p>
                <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded">
                  {post.category}
                </span>
              </div>
            </div>
          </div>
          <p class="text-gray-700 dark:text-gray-300 mt-2">
            {post.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  /* Default: Light mode - make white SVG black (opposite of white background) */
  .svg-theme {
    filter: brightness(0);
  }
  
  /* Dark mode - keep SVG white (opposite of dark background) */
  :global(.dark) .svg-theme {
    filter: brightness(0) invert(1);
  }

  /* Style for the blog title SVG */
  .blog-title-svg {
    max-width: 500px;
    height: auto;
    display: block;
    margin-left: -50px; /* Shift left to account for SVG internal whitespace */
  }
  
  h1 {
    margin: 0;
    padding: 0;
    display: block;
  }
  
  @media (max-width: 640px) {
    .blog-title-svg {
      margin-left: 0; /* Reset on mobile */
      max-width: 100%;
    }
  }
</style>
