---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-start mb-8">
      <h1 class="text-5xl font-bold">CV</h1>
      <a href="/sam_boshar_resume_1-2026.pdf" download class="text-black dark:text-white hover:opacity-70 mr-12" aria-label="Download PDF">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
        </svg>
      </a>
    </div>

    <div class="flex gap-8">
      <!-- Sidebar Navigation -->
      <aside class="w-48 flex-shrink-0">
        <nav class="sticky top-24 space-y-2">
          <a href="#education" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Education</a>
          <a href="#experience" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Experience</a>
          <a href="#publications" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Publications</a>
          <a href="#projects" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Projects</a>
          <a href="#honors" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Honors and Awards</a>
          <a href="#skills" class="block text-sm hover:text-gray-600 dark:hover:text-gray-400 transition-colors">Skills</a>
        </nav>
      </aside>

      <!-- Main Content -->
      <div class="flex-1 space-y-6">

    <!-- Education -->
    <section id="education" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Education</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2024</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">Masters of Engineering in Computer Science</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> MIT
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">
                <a href="https://dspace.mit.edu/handle/1721.1/156816" target="_blank" rel="noopener noreferrer" class="hover:underline">
                  Genomic Language Models for Protein Function and Property Prediction
                </a>; Advisor: Dr. Manolis Kellis <i class="fa-solid fa-dna"></i>
              </li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2023</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">B.S., Double Major in Computer Science and Math, Minor in Brain Cognitive Science</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> MIT
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">GPA 4.9/5.0</li>
              <li class="list-disc">D1 Men's Varsity Lightweight Crew (Captain)</li>
              <li class="list-disc">Phi Beta Kappa, Xi, 2023</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2019</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">Highschool</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> Phillips Academy Andover
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Cum Laude Society</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Work Experience -->
    <section id="experience" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Experience</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2024 - PRESENT</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">ML Research Engineer</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> InstaDeep Ltd (BioNTech)
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Developing (generative) foundation models for genomics <i class="fa-solid fa-dna"></i></li>
              <li class="list-disc">Led pre-training of U-Net based genomic foundation models on &gt;10T tokens and up to 1M-token contexts</li>
              <li class="list-disc">Developed a masked diffusion framework for controllable sequence generation; applied it to design promoter-specific enhancers achieving on average a 4x higher activity on target promoters than background, validated in cellulo</li>
              <li class="list-disc">Achieved state-of-the-art functional genomic assay prediction and genome annotation</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2023 - 2024</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">ML Research Intern <span class="text-xs font-normal">(M.Eng Co-op)</span></h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> InstaDeep Ltd (BioNTech)
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Researching how foundation language models can unify genomics and proteomics <i class="fa-solid fa-dna"></i></li>
              <li class="list-disc">Work published in Oxford Bioinformatics and presented at ICLR MLGenx and AAAI LLMs4Bio workshops</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2022</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">ML Research Intern</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> Dyno Therapeutics, Inc.
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Implemented generative methods for viral protein capsid design via large sequence models</li>
              <li class="list-disc">Led exploration of transformers for modeling fitness functions, replacing previous internal methods</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2020 - 2021</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">Undergraduate Researcher in CS</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> MIT Computer Science and Artificial Intelligence Lab - Antonio Torralba Lab
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Implemented RL algorithms for novelty robust navigation and software for novelty injection and interpretability</li>
              <li class="list-disc">Built pipeline for network dissection, evaluating alignment between hidden units and semantic ideas</li>
            </ul>
          </div>
        </div>

        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2019 - 2020</span>
          <div class="flex-1">
            <h3 class="font-bold text-lg mb-1">Undergraduate Researcher in Biology</h3>
            <p class="text-sm mb-3 flex items-center gap-1 opacity-70">
              <i class="fa-solid fa-building"></i> MIT Synthetic Biology Group - Timothy Lu Lab
            </p>
            <ul class="text-sm space-y-1.5 ml-4">
              <li class="list-disc">Conducted research on engineered programmable bacteria as drug delivery vehicles for cancer therapeutics</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section id="publications" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Publications</h2>
      <ul class="text-sm space-y-3 ml-4">
        <li class="list-disc">
          <strong>Boshar, S.</strong>, Evans, B., Tang, Z., Picard, A., Adel, Y., Lorbeer, F. K., et al. (2025). A foundational model for joint sequence-function multi-species modeling at scale for long-range genomic prediction. <em>bioRxiv</em> (preprint). <a href="https://www.biorxiv.org/content/10.64898/2025.12.22.695963v1" target="_blank" rel="noopener noreferrer" class="hover:underline">[PDF]</a>
        </li>
        <li class="list-disc">
          <strong>Boshar, S.</strong>, Trop, E., de Almeida, B. P., Copoiu, L., Pierrot, T. (2024). "Are genomic language models all you need? Exploring genomic language models on protein downstream tasks." <em>Bioinformatics</em>, 40(9), btae529. <a href="https://academic.oup.com/bioinformatics/article/40/9/btae529/7745814" target="_blank" rel="noopener noreferrer" class="hover:underline">[PDF]</a>
        </li>
        <li class="list-disc">
          Schiff, Y., Sahoo, S. S., Phung, H., Wang, G., <strong>Boshar, S.</strong>, Dalla-torre, H., de Almeida, B. P., Rush, A., Pierrot, T., & Kuleshov, V. (2024). "Simple Guidance Mechanisms for Discrete Diffusion Models". In <em>Proceedings of the International Conference on Learning Representations (ICLR 2025)</em>. <a href="https://proceedings.iclr.cc/paper_files/paper/2025/file/6cc31b44d88dce8380d36e81485cd07f-Paper-Conference.pdf" target="_blank" rel="noopener noreferrer" class="hover:underline">[PDF]</a>
        </li>
      </ul>
    </section>

    <!-- Projects -->
    <section id="projects" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Projects</h2>
      <div class="space-y-4 text-sm">
        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2021 - 2022</span>
          <div class="flex-1">
            <h3 class="font-bold mb-1">Directed Research Project in Quantum Computation</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">MIT Department of Math</p>
            <p>Quantum computing via Nielsen & Chuang culminating in a symposium presentation on quantum key distribution.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded h-fit">2020</span>
          <div class="flex-1">
            <h3 class="font-bold mb-1">Reinforcement Learning Visualizer</h3>
            <p>Co-developed 'gridworld' visualization for RL algorithms: value iteration, SARSA, Q-learning, and REINFORCE.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Honors & Awards -->
    <section id="honors" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Honors and Awards</h2>
      <p class="text-sm">Varsity Rowing Captain | Most Inspirational Brother (ΦΣK) | Most Inspirational 2022 (MIT Rowing) | Phi Beta Kappa</p>
    </section>

    <!-- Skills -->
    <section id="skills" class="border-2 border-black dark:border-white rounded-lg p-6">
      <h2 class="text-3xl font-bold mb-6">Skills</h2>
      <div class="text-sm space-y-2">
        <p><strong>ML Frameworks:</strong> Jax/Flax/Haiku, Pytorch (Lightning)</p>
        <p><strong>Infra/tools:</strong> multi-node GPUs/TPUs, AWS S3, GCP, Tensorboard Profiling, Neptune.ai, Docker, Megatron-LM</p>
      </div>
    </section>

      </div>
    </div>
  </div>
</BaseLayout>
