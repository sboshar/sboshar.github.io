---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteHref } from '../lib/site-url';
---

<BaseLayout title="CV">
  <div class="max-w-3xl mx-auto">
    <!-- Header -->
    <div class="flex justify-between items-start mb-6">
      <h1 class="text-3xl font-normal">CV</h1>
      <a href={siteHref('sam_boshar_resume_1-2026.pdf')} download class="text-sm hover:underline" aria-label="Download PDF">
        Download PDF
      </a>
    </div>

    <!-- Main Content -->
    <div class="space-y-6">

    <!-- Education -->
    <section id="education">
      <h2 class="text-xl font-normal mb-3">Education</h2>
      <div class="space-y-4">
        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Masters of Engineering in Computer Science, <span class="text-gray-500 dark:text-gray-400">MIT</span></h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2024</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <a href="https://dspace.mit.edu/handle/1721.1/156816" target="_blank" rel="noopener noreferrer" class="hover:underline text-gray-700 dark:text-gray-300">
              Genomic Language Models for Protein Function and Property Prediction
            </a>; Advisor: Dr. Manolis Kellis
          </p>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">B.S., Double Major in Computer Science and Math, Minor in Brain Cognitive Science, <span class="text-gray-500 dark:text-gray-400">MIT</span></h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2023</span>
          </div>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>GPA 4.9/5.0</li>
            <li>D1 Men's Varsity Lightweight Crew (Captain)</li>
            <li>Phi Beta Kappa, Xi, 2023</li>
          </ul>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Highschool, <span class="text-gray-500 dark:text-gray-400">Phillips Academy Andover</span></h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2019</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">Cum Laude Society</p>
        </div>
      </div>
    </section>

    <!-- Work Experience -->
    <section id="experience" class="pt-2 divider-rule-t">
      <h2 class="text-xl font-normal mb-3">Experience</h2>
      <div class="space-y-4">
        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">ML Research Engineer</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2024 - PRESENT</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">InstaDeep Ltd (BioNTech)</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>Developed a large-scale, JAX-vectorized cancer screening simulator and leveraged it to train RL agents that optimize screening decisions under partial observability</li>
            <li>Led pre-training of U-Net based genomic foundation models on &gt;10T tokens and up to 1M-token contexts</li>
            <li>Developed a masked diffusion framework for controllable sequence generation; applied it to design promoter-specific enhancers achieving on average a 4x higher activity on target promoters than background, validated in cellulo</li>
            <li>Achieved state-of-the-art functional genomic assay prediction and genome annotation</li>
          </ul>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">ML Research Intern <span class="font-normal">(M.Eng Co-op)</span></h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2023 - 2024</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">InstaDeep Ltd (BioNTech)</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>Researching how foundation language models can unify genomics and proteomics</li>
            <li>Work published in Oxford Bioinformatics and presented at ICLR MLGenx and AAAI LLMs4Bio workshops</li>
          </ul>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">ML Research Intern</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2022</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">Dyno Therapeutics, Inc.</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>Implemented generative methods for viral protein capsid design via large sequence models</li>
            <li>Led exploration of transformers for modeling fitness functions, replacing previous internal methods</li>
          </ul>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Undergraduate Researcher in CS</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2020 - 2021</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">MIT Computer Science and Artificial Intelligence Lab - Antonio Torralba Lab</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>Implemented RL algorithms for novelty robust navigation and software for novelty injection and interpretability</li>
            <li>Built pipeline for network dissection, evaluating alignment between hidden units and semantic ideas</li>
          </ul>
        </div>

        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Undergraduate Researcher in Biology</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2019 - 2020</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">MIT Synthetic Biology Group - Timothy Lu Lab</p>
          <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-0.5 list-disc pl-5">
            <li>Conducted research on engineered programmable bacteria as drug delivery vehicles for cancer therapeutics</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section id="publications" class="pt-2 divider-rule-t">
      <h2 class="text-xl font-normal mb-3">Publications</h2>
      <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
        <li>
          <strong class="text-gray-900 dark:text-gray-100">Boshar, S.</strong>, Evans, B., Tang, Z., Picard, A., Adel, Y., Lorbeer, F. K., et al. (2025). A foundational model for joint sequence-function multi-species modeling at scale for long-range genomic prediction. <em>bioRxiv</em> (preprint). <a href="https://www.biorxiv.org/content/10.64898/2025.12.22.695963v1" target="_blank" rel="noopener noreferrer" class="hover:underline text-gray-700 dark:text-gray-300">[PDF]</a>
        </li>
        <li>
          <strong class="text-gray-900 dark:text-gray-100">Boshar, S.</strong>, Trop, E., de Almeida, B. P., Copoiu, L., Pierrot, T. (2024). "Are genomic language models all you need? Exploring genomic language models on protein downstream tasks." <em>Bioinformatics</em>, 40(9), btae529. <a href="https://academic.oup.com/bioinformatics/article/40/9/btae529/7745814" target="_blank" rel="noopener noreferrer" class="hover:underline text-gray-700 dark:text-gray-300">[PDF]</a>
        </li>
        <li>
          Schiff, Y., Sahoo, S. S., Phung, H., Wang, G., <strong class="text-gray-900 dark:text-gray-100">Boshar, S.</strong>, Dalla-torre, H., de Almeida, B. P., Rush, A., Pierrot, T., & Kuleshov, V. (2024). "Simple Guidance Mechanisms for Discrete Diffusion Models". In <em>Proceedings of the International Conference on Learning Representations (ICLR 2025)</em>. <a href="https://proceedings.iclr.cc/paper_files/paper/2025/file/6cc31b44d88dce8380d36e81485cd07f-Paper-Conference.pdf" target="_blank" rel="noopener noreferrer" class="hover:underline text-gray-700 dark:text-gray-300">[PDF]</a>
        </li>
      </ul>
    </section>

    <!-- Projects -->
    <section id="projects" class="pt-2 divider-rule-t">
      <h2 class="text-xl font-normal mb-3">Projects</h2>
      <div class="space-y-3 text-sm">
        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Directed Research Project in Quantum Computation</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2021 - 2022</span>
          </div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1 italic">MIT Department of Math</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Quantum computing via Nielsen & Chuang culminating in a symposium presentation on quantum key distribution.</p>
        </div>
        <div>
          <div class="flex justify-between items-start mb-0.5">
            <h3 class="font-semibold">Reinforcement Learning Visualizer</h3>
            <span class="text-xs text-gray-500 dark:text-gray-400">2020</span>
          </div>
          <p class="text-sm text-gray-600 dark:text-gray-400">Co-developed 'gridworld' visualization for RL algorithms: value iteration, SARSA, Q-learning, and REINFORCE.</p>
        </div>
      </div>
    </section>

    <!-- Honors & Awards -->
    <section id="honors" class="pt-2 divider-rule-t">
      <h2 class="text-xl font-normal mb-3">Honors and Awards</h2>
      <p class="text-sm text-gray-600 dark:text-gray-400">Varsity Rowing Captain | Most Inspirational Brother (ΦΣK) | Most Inspirational 2022 (MIT Rowing) | Phi Beta Kappa</p>
    </section>

    <!-- Skills -->
    <section id="skills" class="pt-2 divider-rule-t">
      <h2 class="text-xl font-normal mb-3">Skills</h2>
      <div class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
        <p><strong class="text-gray-900 dark:text-gray-100">ML Frameworks:</strong> Jax/Flax/Haiku, Pytorch (Lightning)</p>
        <p><strong class="text-gray-900 dark:text-gray-100">Infra/tools:</strong> multi-node GPUs/TPUs, AWS S3, GCP, Tensorboard Profiling, Neptune.ai, Docker, Megatron-LM</p>
      </div>
    </section>

    </div>
  </div>
</BaseLayout>
