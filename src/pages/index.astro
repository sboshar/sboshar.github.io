---
import BaseLayout from '../layouts/BaseLayout.astro';
import { papers, formatAuthors } from '../data/publications';
import { siteHref } from '../lib/site-url';

const selectedPublications = papers.filter(pub => pub.selected === true);

const selectedProjects = [
  {
    title: 'MànDào',
    subtitleZh: '漫道',
    href: 'https://mandao-sigma.vercel.app/',
    description:
      'Mandarin learning app built on a meaning-centered graph: words in context, recursive exploration, spaced repetition.',
    github: 'https://github.com/sboshar/mandao',
  },
];

/** Absolute homepage URL for SEO / structured data */
const websiteUrl = Astro.site
  ? new URL(import.meta.env.BASE_URL, Astro.site).href
  : '';

const personJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sam Boshar',
  alternateName: 'sboshar',
  url: websiteUrl,
  sameAs: ['https://github.com/sboshar'],
  jobTitle: 'ML Research Engineer',
  worksFor: {
    '@type': 'Organization',
    name: 'InstaDeep',
    url: 'https://www.instadeep.com/',
  },
});
---

<BaseLayout
  title="Sam Boshar — ML research engineer"
  description="Sam Boshar: machine learning research engineer (InstaDeep / BioNTech), genomics foundation models, MIT MEng. Publications, CV, teaching."
  einsteinBg
>
  <script type="application/ld+json" set:html={personJsonLd} slot="head" />
  <div class="space-y-12">
    <div class="space-y-6">
      <h1 class="text-[2.85rem] font-normal leading-none sm:text-[3.05rem]">Sam Boshar</h1>
      <p class="text-lg">
        ML Research Engineer @ <a href="https://www.instadeep.com/" class="hover:underline">InstaDeep</a>
      </p>
    </div>

    <div class="space-y-6">
      <h2 class="text-2xl font-bold">about me</h2>

      <div class="space-y-4 text-lg leading-relaxed">
        <p>
          I am a research engineer @ <a href="https://www.instadeep.com/">InstaDeep</a> (now <a href="https://www.biontech.com/int/en/home.html">BioNTech</a>), where I work on developing generative foundation models for genomics <i class="fa-solid fa-dna"></i>. This work builds on my master&apos;s <a href="https://dspace.mit.edu/handle/1721.1/156816?show=full">thesis</a> (MIT), where I studied transformers as a unified approach to model genomics and proteomics.
        </p>
        <p>
          I earned my undergraduate degree at MIT, where I double majored in Computer Science <i class="fa-solid fa-code"></i> and Math and minored in Brain and Cognitive Sciences <i class="fa-solid fa-brain"></i>.
        </p>
        <p>
          I am most passionate about applying machine learning to solve otherwise intractable problems in science <i class="fa-solid fa-flask-vial"></i>.
        </p>
      </div>
    </div>

    <div class="space-y-6 pt-8 divider-rule-t">
      <h2 class="text-2xl font-bold">Selected Publications</h2>
      <ul class="space-y-6">
        {selectedPublications.map((pub) => {
          const authorInfo = formatAuthors(pub.authors);
          return (
            <li class="flex items-start gap-4 pb-6 divider-rule-b last:border-0">
              <span class="text-xs font-semibold border border-black dark:border-white px-2 py-1 rounded whitespace-nowrap mt-1">
                {pub.abbr}
              </span>
              <div class="flex-1 space-y-1">
                <h3 class="text-lg font-medium">
                  <a href={pub.link} class="hover:underline">
                    {pub.title}
                  </a>
                </h3>
                <p class="text-sm">
                  <span set:html={authorInfo.html} />
                  {authorInfo.hasMore && (
                    <a href={pub.link} class="underline hover:no-underline">
                      {authorInfo.moreCount} more author{authorInfo.moreCount > 1 ? 's' : ''}
                    </a>
                  )}
                </p>
                <p class="text-sm italic text-gray-600 dark:text-gray-400">
                  {pub.journal}, {pub.year}
                  {pub.doi && (
                    <span> • <a href={`https://doi.org/${pub.doi}`} class="hover:underline not-italic">DOI</a></span>
                  )}
                </p>
              </div>
            </li>
          );
        })}
      </ul>
      <p class="pt-4">
        <a href={siteHref('publications')} class="text-gray-600 dark:text-gray-400 hover:underline">
          See all publications →
        </a>
      </p>
    </div>

    <div class="space-y-6 pt-8 divider-rule-t">
      <h2 class="text-2xl font-bold">Selected Projects</h2>
      <ul class="space-y-6">
        {selectedProjects.map((proj) => (
          <li class="pb-6 divider-rule-b last:border-0">
            <h3 class="text-lg font-medium">
              <a href={proj.href} class="hover:underline" target="_blank" rel="noopener noreferrer">
                {proj.title}
              </a>
              <span class="font-normal text-gray-600 dark:text-gray-400"> ({proj.subtitleZh})</span>
            </h3>
            <p class="text-sm text-gray-700 dark:text-gray-300 mt-1 leading-relaxed">{proj.description}</p>
            <p class="text-sm mt-2">
              <a
                href={proj.github}
                class="text-gray-600 dark:text-gray-400 hover:underline"
                target="_blank"
                rel="noopener noreferrer"
              >
                GitHub →
              </a>
            </p>
          </li>
        ))}
      </ul>
    </div>

    <!-- Social Links -->
    <div class="pt-8 divider-rule-t">
      <div class="flex items-center gap-6">
        <a href="mailto:s.t.boshar@gmail.com" class="text-black dark:text-white hover:opacity-70 transition-opacity" aria-label="Email">
          <i class="fa-solid fa-envelope text-xl"></i>
        </a>
        <a href="https://github.com/sboshar" target="_blank" rel="noopener noreferrer" class="text-black dark:text-white hover:opacity-70 transition-opacity" aria-label="GitHub">
          <i class="fa-brands fa-github text-xl"></i>
        </a>
        <a href="https://www.linkedin.com/in/sam-boshar" target="_blank" rel="noopener noreferrer" class="text-black dark:text-white hover:opacity-70 transition-opacity" aria-label="LinkedIn">
          <i class="fa-brands fa-linkedin text-xl"></i>
        </a>
        <a href="https://medium.com/@sam-boshar" target="_blank" rel="noopener noreferrer" class="text-black dark:text-white hover:opacity-70 transition-opacity" aria-label="Medium">
          <i class="fa-brands fa-medium text-xl"></i>
        </a>
      </div>
    </div>

  </div>
</BaseLayout>
