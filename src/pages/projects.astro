---
import BaseLayout from '../layouts/BaseLayout.astro';

// Dummy projects
const projects = [
  {
    title: "Project Alpha",
    description: "A web application for managing distributed workflows",
    year: "2024",
    link: "#",
    tags: ["React", "Node.js", "TypeScript"]
  },
  {
    title: "Project Beta",
    description: "Machine learning framework for real-time predictions",
    year: "2023",
    link: "#",
    tags: ["Python", "TensorFlow", "Docker"]
  },
  {
    title: "Project Gamma",
    description: "Open-source library for data visualization",
    year: "2023",
    link: "#",
    tags: ["JavaScript", "D3.js", "WebGL"]
  },
  {
    title: "Project Delta",
    description: "Mobile app for collaborative note-taking",
    year: "2022",
    link: "#",
    tags: ["React Native", "Firebase", "GraphQL"]
  }
];
---

<BaseLayout title="Projects">
  <div class="space-y-12">
    <div class="space-y-4">
      <h1 class="text-4xl font-bold">Projects</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        A selection of projects I've worked on.
      </p>
    </div>

    <div class="space-y-8">
      {projects.map((project) => (
        <article class="space-y-2 pb-8 border-b border-divider last:border-0">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <h2 class="text-xl font-semibold">
                <a href={project.link} class="hover:underline">
                  {project.title}
                </a>
              </h2>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">
                {project.year}
              </p>
            </div>
          </div>
          <p class="text-gray-700 dark:text-gray-300 mt-2">
            {project.description}
          </p>
          <div class="flex flex-wrap gap-2 mt-3">
            {project.tags.map((tag) => (
              <span class="text-xs px-2 py-1 bg-gray-100 dark:bg-gray-800 rounded">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>
