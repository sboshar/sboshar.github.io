---
import BaseLayout from '../layouts/BaseLayout.astro';

const talks = [
  {
    title: "Kipoi Seminar",
    description: "Invited talk, March 2026 (InstaDeep).",
    seriesUrl: "https://kipoi.org/seminar/",
    recordingUrl: "https://www.youtube.com/watch?v=edqZqLfqcBM",
  },
  {
    title: "Are Genomic Language Models All You Need?",
    description: "Exploring genomic language models on protein downstream tasks. AAAI/ICLR workshop.",
    seriesUrl: "https://drive.google.com/file/d/1qgwnesu448IZVvPVcoWpwVoqLVroY8Uk/view?usp=sharing",
    recordingUrl: "https://drive.google.com/file/d/1qgwnesu448IZVvPVcoWpwVoqLVroY8Uk/view?usp=sharing",
  },
];

const lectures = [
  {
    title: "Finite Kakeya Conjecture",
    description:
      "Introductory Lecture on Polynomial Method solution to the Finite Kakeya conjecture as part of 18.204 @ MIT",
    redirect: "https://drive.google.com/file/d/1QCKVmmhYZoHKx0iuogY6KC1ELKU9wApP/view?usp=sharing",
    importance: 1,
  },
  {
    title: "Spiking Hardware",
    description: "Should we mimic spiking in hardware? 3hr lecture taught by myself and Grace Song.",
    redirect: "https://docs.google.com/presentation/d/1QAonRe5iFVq37-iV2sHSKSGwvzh5jB9XSiHMaRJY-L0/edit?usp=sharing",
    importance: 3,
  },
  {
    title: "Quantum Cryptography and Quantum Key Distribution: The BB84 Protocol",
    description: "Overview of quantum key distribution and the BB84 protocol.",
    redirect: "https://docs.google.com/presentation/d/1Xa1g6zumS3vggdBvvY5zfeJ7xoMN2qeL5elulT2BglI/edit?usp=sharing",
    importance: 2,
  },
  {
    title: "Rational Speech Act Framework",
    description: "Computational modeling of pragmatic language understanding using the Rational Speech Act framework.",
    redirect: "https://docs.google.com/presentation/d/1JHCJMbwTjbyDMeFs1RLy-3fXYHhn0gCGvSmo2e7C414/edit?usp=sharing",
    importance: 5,
  },
];

/** Same spacing and rules for every row; last row has no bottom border but keeps padding above the next section. */
const entryArticleClass =
  "pt-6 pb-6 divider-rule-b first:pt-0 last:border-b-0";
---

<BaseLayout title="Teaching">
  <div>
    <header class="space-y-2 pb-8">
      <h1 class="text-4xl font-bold">teaching</h1>
      <p class="text-sm text-gray-600 dark:text-gray-400">
        Lectures I have (co-)taught, plus occasional seminar talks.
      </p>
    </header>

    <section class="divider-rule-t pt-8" aria-labelledby="teaching-talks-heading">
      <h2
        id="teaching-talks-heading"
        class="text-base font-semibold text-gray-500 dark:text-gray-400 mb-6"
      >
        talks
      </h2>
      <div>
        {talks.map((talk) => (
          <article class={entryArticleClass}>
            <h3 class="text-xl font-bold lowercase mb-2">
              <a href={talk.recordingUrl} target="_blank" rel="noopener noreferrer" class="hover:underline">
                {talk.title.toLowerCase()}
              </a>
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">
              {talk.description}{' '}
              <a
                href={talk.seriesUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:underline text-gray-700 dark:text-gray-300"
              >
                Series page
              </a>
              {' · '}
              <a
                href={talk.recordingUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:underline text-gray-700 dark:text-gray-300"
              >
                Recording
              </a>
            </p>
          </article>
        ))}
      </div>
    </section>

    <section class="divider-rule-t pt-8" aria-labelledby="teaching-lectures-heading">
      <h2
        id="teaching-lectures-heading"
        class="text-base font-semibold text-gray-500 dark:text-gray-400 mb-6"
      >
        lectures
      </h2>
      <div>
        {lectures.map((lecture) => (
          <article class={entryArticleClass}>
            <h3 class="text-xl font-bold lowercase mb-2">
              <a href={lecture.redirect} target="_blank" rel="noopener noreferrer" class="hover:underline">
                {lecture.title.toLowerCase()}
              </a>
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400">{lecture.description}</p>
          </article>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
